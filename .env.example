# ─── Restless Field Toolkit — Environment Variables ───────────────────────────
#
# Copy this file to .env and fill in values as needed.
# Variables prefixed with VITE_ are exposed to the browser at build time.
# All variables listed here are OPTIONAL unless marked REQUIRED.
#
# ─── Google Maps ──────────────────────────────────────────────────────────────

# Direct Google Maps API key (preferred). Requires Maps JavaScript API enabled
# in Google Cloud Console. When set, maps load directly from maps.googleapis.com.
# Without a key the map renders a "Map Unavailable" placeholder — no crash.
# VITE_GOOGLE_MAPS_API_KEY=

# Google Cloud Map ID for styled/advanced maps (AdvancedMarkerElement support).
# Create one at: https://console.cloud.google.com/google/maps-apis/maps
# Falls back to DEMO_MAP_ID (development-only placeholder) when not set.
# VITE_GOOGLE_MAP_ID=

# ─── Google Maps / Frontend Forge (alternative proxy) ─────────────────────────

# API key for the Frontend Forge Maps proxy (used if VITE_GOOGLE_MAPS_API_KEY
# is not set). Without either key the map shows a placeholder.
# VITE_FRONTEND_FORGE_API_KEY=

# Base URL for the Frontend Forge proxy (defaults to https://forge.butterfly-effect.dev).
# VITE_FRONTEND_FORGE_API_URL=

# ─── Analytics (Umami) ────────────────────────────────────────────────────────

# Self-hosted Umami instance base URL (e.g. https://analytics.example.com).
# Analytics script is skipped silently when this is not set.
# VITE_ANALYTICS_ENDPOINT=

# Umami website ID (UUID from the Umami dashboard).
# VITE_ANALYTICS_WEBSITE_ID=

# ─── OAuth / Auth Portal ──────────────────────────────────────────────────────

# Base URL of the OAuth portal (e.g. https://auth.example.com).
# getLoginUrl() returns null when this is not set — no crash.
# VITE_OAUTH_PORTAL_URL=

# Application ID registered in the OAuth portal.
# VITE_APP_ID=
